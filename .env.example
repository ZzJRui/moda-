# AI 衣柜部署环境变量示例
# 用法：在服务器上 `cp .env.example .env` 后填入真实值，再 docker compose up -d
# 注意：.env 已被 .gitignore 忽略，不会入库；不要把真实 key 提交到 git。

# ===== AI 凭据（推荐 + 识图打标签共用，必填，否则 AI 功能不可用）=====
AI_RECOMMENDATION_PROVIDER=openai_compatible
AI_API_BASE_URL=https://your-provider.com/v1
AI_API_KEY=your-key
AI_MODEL=your-model
AI_TIMEOUT_SECONDS=60

# ===== AI 识图打标签开关（默认 true，上传时自动打标签）=====
AI_TAGGING_ENABLED=true

# ===== 图片处理（rembg 抠图 + 白底）=====
# 生产建议 true；若服务器内存吃紧或不想首次下载 u2net 模型，可设 false 退化为原图
IMAGE_PROCESSING_ENABLED=true

# ===== CORS（可选）=====
# 同容器同源访问时不需要；若前端单独部署到别的域名才需要加
# CORS_ORIGINS=https://your-domain.com
